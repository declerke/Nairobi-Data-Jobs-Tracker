# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password

# Email notifications (set ENABLE_EMAIL_NOTIFICATIONS=False to disable)
ENABLE_EMAIL_NOTIFICATIONS=False
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENT=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Scraping behaviour
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=8
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_JOBS_PER_SITE=200

# Scrapers (set False to disable individual sources)
ENABLE_BRIGHTERMONDAY=True
ENABLE_MYJOBMAG=True
ENABLE_FUZU=True

# Keyword matching — jobs matching any of these trigger email alerts
TARGET_KEYWORDS=Python,SQL,Data Engineer,Data Analyst,Data Scientist,ETL,ELT,Analytics,PostgreSQL,MySQL,BigQuery,Snowflake,Airflow,Kafka,Spark,dbt,Pandas,AWS,Azure,GCP,Docker,Kubernetes,Terraform,FastAPI,Flask,Machine Learning,Power BI,Tableau,Looker
MIN_KEYWORDS_FOR_ALERT=1

# Logging
LOG_LEVEL=INFO
TIMEZONE=Africa/Nairobi
